{
  "server": {
    "host": "0.0.0.0",
    "port": 8080,
    "threads": 4,
    "mode": "single_node",
    "tls": {
      "enabled": false,
      "certificate": "config/ssl/server.crt",
      "private_key": "config/ssl/server.key"
    },
    "limits": {
      "max_body_bytes": 268435456,
      "request_timeout_ms": 30000,
      "rate_limit_rps": 0,
      "rate_limit_burst": 0
    }
  },
  "storage": {
    "base_path": "data",
    "temp_path": "data/tmp",
    "multipart": {
      "max_upload_ttl_seconds": 86400
    }
  },
  "cleanup": {
    "enabled": true,
    "sweep_interval_seconds": 300,
    "grace_period_seconds": 60,
    "max_uploads_per_sweep": 200
  },
  "observability": {
    "log_level": "information"
  },
  "auth": {
    "enabled": true,
    "issuer": "http://127.0.0.1:8081/realms/master",
    "audience": "",
    "jwks_url": "http://127.0.0.1:8081/realms/master/protocol/openid-connect/certs",
    "cache_ttl_seconds": 300,
    "clock_skew_seconds": 60,
    "allowed_alg": "RS256"
  },
  "distributed": {
    "metadata_base_url": "http://127.0.0.1:9091",
    "storage_nodes": [
      "http://127.0.0.1:9092",
      "http://127.0.0.1:9093"
    ],
    "service_auth_token": "change-me-for-production",
    "replication_factor": 2,
    "min_write_acks": 2
  }
}
